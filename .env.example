# Copy this file to .env for local development.
# Never commit a real .env — it is in .gitignore.

# ── Backend ───────────────────────────────────────────────────────────────────
APP_ENV=development
DB_PATH=/data/todo.db

# Change this to any random string locally.
# In production this value comes from AWS Secrets Manager — never set it here.
JWT_SECRET_KEY=replace-me-with-a-random-string

# ── GitHub Actions secrets (set in GitHub repo Settings → Secrets) ─────────────
# These are never stored in files — listed here for documentation only.
#
# AWS_ACCOUNT_ID  — your 12-digit AWS account number
#                   Used to construct ECR URLs and IAM role ARNs in the workflows.
